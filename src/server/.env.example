# BIND_ADDR=0.0.0.0 will expose the server to your local network
# BIND_ADDR=127.0.0.1 is the secure default (loopback only)
BIND_ADDR=127.0.0.1

PORT=3000

# Directory where your .gguf or .bin models are stored
MODEL_DIR=./models

# Default model to load on startup
WHISPER_MODEL=small.en

# "auto" will fallback to CPU if no GPU is found
# "require" will fail to start if no GPU is found
GPU_MODE=auto

# The order to try hardware backends. First available wins.
DEVICE_PRIORITY=cuda,vulkan,cpu

# Max number of clients that can queue jobs before rejecting
MAX_QUEUE_DEPTH=10
